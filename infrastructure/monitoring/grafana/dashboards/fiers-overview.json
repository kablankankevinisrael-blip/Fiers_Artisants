{  "id": null,  "uid": "fiers-overview",  "title": "Fiers Artisans - Overview",  "tags": ["fiers", "api", "prometheus"],  "timezone": "browser",  "schemaVersion": 38,  "version": 1,  "refresh": "10s",  "time": {    "from": "now-6h",    "to": "now"  },  "panels": [    {      "id": 1,      "type": "stat",      "title": "Prometheus UP Targets",      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },      "targets": [        {          "expr": "sum(up)",          "refId": "A"        }      ],      "datasource": {        "type": "prometheus",        "uid": "prometheus"      }    },    {      "id": 2,      "type": "timeseries",      "title": "Targets Up/Down",      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },      "targets": [        {          "expr": "up",          "legendFormat": "{{job}} - {{instance}}",          "refId": "A"        }      ],      "datasource": {        "type": "prometheus",        "uid": "prometheus"      }    },    {      "id": 3,      "type": "timeseries",      "title": "Prometheus Scrape Duration",      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },      "targets": [        {          "expr": "rate(prometheus_target_interval_length_seconds_sum[5m])",          "legendFormat": "{{interval}}",          "refId": "A"        }      ],      "datasource": {        "type": "prometheus",        "uid": "prometheus"      }    },    {      "id": 4,      "type": "table",      "title": "Current Targets",      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },      "targets": [        {          "expr": "up",          "format": "table",          "instant": true,          "refId": "A"        }      ],      "transformations": [        {          "id": "labelsToFields",          "options": {            "mode": "columns"          }        }      ],      "datasource": {        "type": "prometheus",        "uid": "prometheus"      }    }  ]}