<?xml version="1.0" encoding="utf-8"?>
<!--
  Fiers Artisans — Network Security Config
  Autorise le trafic HTTP cleartext vers les serveurs de développement local.
  En production, remplacer par des connexions HTTPS uniquement.
-->
<network-security-config>
    <!-- Domaines de développement autorisés en cleartext -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.1.4</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
