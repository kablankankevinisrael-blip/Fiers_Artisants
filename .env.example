# ══════════════════════════════════════════════════════════════════════
# Fiers Artisans — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs marquées "change_me"
# ══════════════════════════════════════════════════════════════════════
#
# 🛡️  Secrets : toutes les valeurs "change_me_*" DOIVENT être remplacées.
# En production, le serveur refusera de démarrer si elles ne sont pas changées.
#
# 📱 Frontend Flutter : les variables réseau (IP, port, scheme) sont
#    passées via --dart-define au moment du build, pas via ce fichier.
#    Voir la section "Flutter" en bas de ce fichier.
# ══════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────
# En dev local : host=localhost, port=5434 (port hôte Docker)
# En Docker    : host=postgres, port=5432 (port interne)
POSTGRES_USER=fiers_artisans
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=fiers_artisans
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# ── MongoDB ────────────────────────────────────────────────────────────
# En dev local : host=localhost, port=27018 (port hôte Docker)
# En Docker    : host=mongodb, port=27017 (port interne)
MONGO_USER=fiers_artisans
MONGO_PASSWORD=change_me_mongo
MONGO_DB=fiers_artisans
MONGO_HOST=localhost
MONGO_PORT=27018

# ── Redis ──────────────────────────────────────────────────────────────
# En dev local : host=localhost, port=6380 (port hôte Docker)
# En Docker    : host=redis, port=6379 (port interne)
REDIS_PASSWORD=change_me_redis
REDIS_HOST=localhost
REDIS_PORT=6380

# ── MinIO (S3-compatible) ──────────────────────────────────────────────
# En dev local : endpoint=localhost, port=9002 (port hôte Docker)
# En Docker    : endpoint=minio, port=9000 (port interne)
MINIO_ACCESS_KEY=change_me_minio_access
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_BUCKET_PORTFOLIO=portfolio
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_MEDIA=media

# ── JWT ────────────────────────────────────────────────────────────────
# Secret DOIT contenir au moins 32 caractères en production
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

# ── WhatsApp Business Cloud API (Meta) ─────────────────────────────────
# Provider OTP principal. Laisser API_TOKEN vide en dev → log OTP en console.
WHATSAPP_PROVIDER_ENABLED=true
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE_NAME=fiers_artisans_otp

# ── SMS Fallback (Twilio) — Désactivé par défaut ──────────────────────
SMS_PROVIDER_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── OTP Configuration ────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_SENDS_PER_HOUR=3
OTP_BLOCK_DURATION_SECONDS=900

# ── OTP Dev Inspector (désactivé par défaut) ─────────────────────────
# Active un endpoint GET /api/v1/dev/otp/latest consultable en navigateur.
# NE JAMAIS activer en production.
OTP_DEV_INSPECTOR=false
OTP_DEV_KEY=change_me_dev_key

# ── Wave CI (Paiement) ────────────────────────────────────────────────
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=change_me_wave_webhook
WAVE_MERCHANT_ID=

# ── Firebase Cloud Messaging ──────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ── App (NestJS) ──────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Rate Limiting ─────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=30

# ── Monitoring (Grafana) ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# ══════════════════════════════════════════════════════════════════════
# 📱 Flutter — Configuration réseau
# ══════════════════════════════════════════════════════════════════════
#
# Le frontend Flutter lit ses variables depuis : fiers_artisans_app/.env
# Voir fiers_artisans_app/.env.example pour le template.
#
# Pour changer l'IP backend :
#   1. Ouvrir fiers_artisans_app/.env
#   2. Modifier API_HOST=votre_ip
#   3. Hot restart (R) ou relancer flutter run
# ══════════════════════════════════════════════════════════════════════
