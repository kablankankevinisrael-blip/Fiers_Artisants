# ══════════════════════════════════════════════════════════════════════
# Fiers Artisans — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# ══════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=fiers_artisans
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=fiers_artisans
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── MongoDB ────────────────────────────────────────────────────────────
MONGO_USER=fiers_artisans
MONGO_PASSWORD=change_me_mongo
MONGO_DB=fiers_artisans
MONGO_HOST=mongodb
MONGO_PORT=27017
DATABASE_MONGO_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=admin

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ── MinIO (S3-compatible) ──────────────────────────────────────────────
MINIO_ACCESS_KEY=fiers_artisans_minio
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_PORTFOLIO=portfolio
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_MEDIA=media

# ── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d

# ── WhatsApp Business Cloud API (Meta) ─────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_OTP_TEMPLATE_NAME=fiers_artisans_otp

# ── SMS Fallback (Twilio) — Désactivé par défaut ──────────────────────
SMS_PROVIDER_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Wave CI (Paiement) ────────────────────────────────────────────────
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=your_wave_api_key
WAVE_WEBHOOK_SECRET=your_wave_webhook_secret
WAVE_MERCHANT_ID=your_wave_merchant_id

# ── Firebase Cloud Messaging ──────────────────────────────────────────
FCM_PROJECT_ID=your_firebase_project_id
FCM_PRIVATE_KEY=your_firebase_private_key
FCM_CLIENT_EMAIL=your_firebase_client_email

# ── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Monitoring (Grafana) ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana
